    {
        "id": "parse_data",
        "type": "function",
        "z": "flow_tab_main",
        "name": "📦 Build InfluxDB Point",
        "func": "// Flatten ESP32 JSON into direct field values for InfluxDB\nvar d = msg.payload;\n\nmsg.payload = {\n    vib_rms: parseFloat(d.vib_rms) || 0,\n    vib_peak: parseFloat(d.vib_peak) || 0,\n    vib_crest: parseFloat(d.vib_crest) || 0,\n    vib_kurt: parseFloat(d.vib_kurt) || 0,\n    cur_rms: parseFloat(d.cur_rms) || 0,\n    cur_std: parseFloat(d.cur_std) || 0,\n    dom_freq: parseFloat(d.dom_freq) || 0,\n    spec_rms: parseFloat(d.spec_rms) || 0,\n    spec_cent: parseFloat(d.spec_cent) || 0,\n    band1: parseFloat(d.band1) || 0,\n    band2: parseFloat(d.band2) || 0,\n    band3: parseFloat(d.band3) || 0,\n    anomaly_score: parseFloat(d.anomaly_score) || 0,\n    anomaly_label: parseInt(d.anomaly_label) || 0,\n    min_dist: parseFloat(d.min_dist) || 0,\n    cluster: parseInt(d.cluster) || 0,\n    relay: d.relay ? 1 : 0,\n    rssi: parseInt(d.rssi) || 0\n};\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 470,
        "y": 120,
        "wires": [
            [
                "influx_write"
            ]
        ]
    },
