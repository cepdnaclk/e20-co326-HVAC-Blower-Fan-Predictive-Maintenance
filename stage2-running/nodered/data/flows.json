    {
        "id": "check_threshold",
        "type": "function",
        "z": "flow_tab_alerts",
        "name": "🚨 Check Anomaly Thresholds",
        "func": "var score = msg.payload.anomaly_score;\nvar label = msg.payload.anomaly_label;\nvar WARN_THR = 0.0035;\nvar CRIT_THR = 0.05;\n\n// Rate limit: only alert once per minute per level\nvar now = Date.now();\nvar lastAlert = flow.get('lastAlert') || 0;\n\nif (label === 2 && (now - lastAlert > 60000)) {\n    // CRITICAL\n    flow.set('lastAlert', now);\n    msg.payload = {\n        level: 'CRITICAL',\n        score: score,\n        message: '🚨 CRITICAL: Fan vibration anomaly detected! Score: ' + score.toFixed(4) + '. Auto-shutdown initiated.',\n        timestamp: new Date().toISOString()\n    };\n    node.status({fill:'red', shape:'dot', text:'CRITICAL ' + score.toFixed(4)});\n    return [msg, null];\n} else if (label === 1 && (now - lastAlert > 60000)) {\n    // WARNING\n    flow.set('lastAlert', now);\n    msg.payload = {\n        level: 'WARNING',\n        score: score,\n        message: '⚠️ WARNING: Elevated vibration detected. Score: ' + score.toFixed(4) + '. Schedule maintenance.',\n        timestamp: new Date().toISOString()\n    };\n    node.status({fill:'yellow', shape:'ring', text:'WARNING ' + score.toFixed(4)});\n    return [null, msg];\n} else {\n    node.status({fill:'green', shape:'dot', text:'NORMAL ' + score.toFixed(4)});\n    return [null, null];\n}",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 120,
        "wires": [
            [
                "alert_critical_debug",
                "alert_mqtt_pub"
            ],
            [
                "alert_warning_debug",
                "alert_mqtt_pub"
            ]
        ],
        "outputLabels": [
            "Critical",
            "Warning"
