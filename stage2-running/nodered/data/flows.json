    {
        "id": "relay_get_cmd",
        "type": "function",
        "z": "flow_tab_control",
        "name": "Parse GET param",
        "func": "var state = msg.req.params.state;\nmsg.payload = { relay: (state === 'on' || state === '1' || state === 'true') };\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "x": 420,
        "y": 200,
        "wires": [
            [
                "relay_mqtt_out",
                "relay_response"
            ]
        ]
    },
    {
        "id": "relay_command",
        "type": "function",
        "z": "flow_tab_control",
        "name": "🔧 Build Relay Command",
        "func": "// Expects POST body: { \"relay\": true/false }\nvar cmd = msg.payload;\nif (typeof cmd.relay === 'undefined') {\n    msg.payload = { error: 'Missing relay field. Use {\"relay\": true} or {\"relay\": false}' };\n    msg.statusCode = 400;\n    return [null, msg];\n}\n\nmsg.payload = {\n    relay: cmd.relay === true || cmd.relay === 'true' || cmd.relay === 1\n};\n\nnode.status({fill: msg.payload.relay ? 'green' : 'red', shape: 'dot', text: msg.payload.relay ? 'ON' : 'OFF'});\n\nreturn [msg, null];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
